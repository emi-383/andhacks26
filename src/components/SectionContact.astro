<section id="contact" aria-labelledby="contact-heading" class="contact-section">
  <div class="contact-shell">
    <div class="contact-copy">
      <p class="contact-kicker">Contact</p>
      <h2 id="contact-heading">Reach the &amp;Hacks team</h2>
      <p>
        Whether you're planning to attend, sponsor, or mentor, send a message
        and our organizers will point you in the right direction.
      </p>
    </div>

    <div class="contact-grid">
      <div
        class="contact-card contact-card-primary contact-copy-card"
        data-email="computing@wm.edu"
        role="button"
        tabindex="0"
        aria-label="Copy computing@wm.edu"
      >
        <span class="contact-copy-hint" aria-hidden="true">Click to copy</span>
        <span class="contact-label">Email</span>
        <strong>computing@wm.edu</strong>
        <span class="contact-meta">General questions, sponsorship, and support</span>
      </div>

      <a
        class="contact-card"
        href="https://discord.gg/ve8JwXSB"
        target="_blank"
        rel="noreferrer"
      >
        <span class="contact-label">Discord</span>
        <strong>Join the community server</strong>
        <span class="contact-meta">Meet teammates, ask quick questions, and stay in the loop</span>
      </a>

      <a
        class="contact-card"
        href="https://www.instagram.com/andhackswm/"
        target="_blank"
        rel="noreferrer"
      >
        <span class="contact-label">Instagram</span>
        <strong>@andhackswm</strong>
        <span class="contact-meta">Follow for announcements, reminders, and event updates</span>
      </a>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 2rem 2rem 6rem;
    scroll-margin-top: 80px;
  }

  .contact-shell {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: 2rem;
    align-items: stretch;
    border: 1px solid currentColor;
    border-radius: 2rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.12), transparent 40%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02));
    backdrop-filter: blur(12px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
  }

  .contact-kicker {
    margin: 0 0 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.85rem;
    opacity: 0.72;
  }

  .contact-copy h2 {
    margin: 0 0 1rem;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1;
  }

  .contact-copy p:last-child {
    margin: 0;
    max-width: 36rem;
    line-height: 1.7;
    opacity: 0.88;
  }

  .contact-grid {
    display: grid;
    gap: 1rem;
  }

  .contact-card {
    border: 1px solid currentColor;
    border-radius: 1.4rem;
    padding: 1.25rem;
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.04);
    transition: background 180ms ease;
  }

  .contact-card:hover,
  .contact-card:focus-visible {
    background: rgba(255, 255, 255, 0.08);
  }

  .contact-card-primary {
    justify-content: center;
  }

  .contact-card,
  .contact-card-primary {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    position: relative;
  }

  .contact-label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    opacity: 0.72;
  }

  .contact-card strong {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
  }

  .contact-meta {
    line-height: 1.5;
    opacity: 0.82;
  }

  .contact-copy-hint {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 180ms ease;
    pointer-events: none;
  }

  .contact-copy-card:hover .contact-copy-hint,
  .contact-copy-card:focus-visible .contact-copy-hint {
    opacity: 0.74;
  }

  .contact-copy-card {
    cursor: pointer;
  }

  .contact-copy-card.copied .contact-copy-hint {
    opacity: 0.9;
  }

  @media (max-width: 900px) {
    .contact-shell {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .contact-section {
      padding-inline: 1rem;
    }
  }
</style>

<script>
  const copyCard = document.querySelector('.contact-copy-card');
  const copyHint = copyCard?.querySelector('.contact-copy-hint');

  async function copyEmail() {
    const email = copyCard.getAttribute('data-email');
    if (!email || !navigator.clipboard) return;

    try {
      await navigator.clipboard.writeText(email);
      if (copyHint) {
        copyHint.textContent = 'Copied!';
      }
      copyCard.classList.add('copied');
      window.setTimeout(() => {
        copyCard.classList.remove('copied');
        window.setTimeout(() => {
          if (copyHint) {
            copyHint.textContent = 'Click to copy';
          }
        }, 180);
      }, 1600);
    } catch {
      // ignore clipboard failures and leave the fallback email visible
    }
  }

  copyCard?.addEventListener('click', copyEmail);
  copyCard?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault();
      copyEmail();
    }
  });
</script>
