---
const registerUrl = "https://wmsas.qualtrics.com/jfe/form/SV_6S8vNLg8wb4xpum";
const sponsorUrl = "https://wmsas.qualtrics.com/jfe/form/SV_57iVqHk2QHKUzpY";
---

<div class="regis-buttons">
  <a href={registerUrl} target="_blank" class="btn btn-register">
    Register
  </a>
  <a href={sponsorUrl} target="_blank" class="btn btn-sponsor">
    Sponsor
  </a>
</div>

<style>
  .regis-buttons {
    display: flex;
    justify-content: flex-start;
    gap: 2rem;
    margin-top: 0.8rem;
  }

  .btn {
  padding: 0.8rem 2rem;
  border-radius: 50px;
  font-size: 1.1rem;
  font-weight: 700;
  text-decoration: none;
  cursor: pointer;
  backdrop-filter: blur(20px) saturate(180%);                  /* w */
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.2);                /* w */
  color: white;
  box-shadow: 
    inset 0 1px 0 rgba(255, 255, 255, 0.3),
    0 4px 24px rgba(0, 0, 0, 0.2);
  text-shadow: none;
  transition: transform 0.2s, box-shadow 0.2s, text-shadow 0.2s, background 0.2s;
}

.btn:hover {
  transform: scale(1.05);
  background: rgba(255, 255, 255, 0.06);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.4),
    0 4px 32px rgba(0, 0, 0, 0.3);
  text-shadow:
    0 0 8px rgba(255, 255, 255, 0.9),
    0 0 20px rgba(255, 255, 255, 0.5);
}
</style>