---
import MainLayout from '../layouts/MainLayout.astro';
import Andy from '../components/Andy.astro';
import ParticleBG from '../components/ParticleBG.astro';
import { Image } from 'astro:assets';
import Intro from '../components/Intro.astro';
import RegisButtons from '../components/RegisButtons.astro';
import Switch from '../components/Switch.astro';
import ArrowTop from '../components/ArrowTop.astro';
import FAQ from '../components/FAQ.astro';
import ContactSection from '../components/ContactSection.astro';
import ScrollPromptArrow from '../components/ScrollPromptArrow.astro';

// Cloudy effects to add later
// import clouds from '../assets/clouds.png'; 
---

<MainLayout title="&Hacks 2026">
  
  <Switch slot="above-filter" />
  <ParticleBG />

  <div class="cloud-layer">
    <div style="width: 100%; height: 100%; background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);"></div>
  </div>

  <main>
    <section id="hero">
      <Switch />
      <div class="hero-title">
        <h1>&amp;Hacks 2026</h1>
        <p>Sept. 25–27</p>
        <RegisButtons />
      </div>
      <div class="hero-andy">
        <Andy />
      </div>

      <ScrollPromptArrow />
    </section>

    <section id="details">
      <div class="intro-area">
         <Intro />
      </div>
    </section>
  <ContactSection />
  </main>
  <FAQ />
  <ArrowTop />
</MainLayout>

<style>
  #hero {
    position: relative;
    height: 100vh;
    width: 100%;
  }

  .hero-title {
    position: absolute;
    top: 8rem;
    left: 6rem;
    z-index: 5;
  }

  h1 {
    font-size: clamp(4rem, 9vw, 8rem);
    font-weight: 900;
    margin: 0;
    line-height: 1;
  }

  .hero-title p {
    font-size: 2rem;
    margin: 0.5rem 0 0 0;
    opacity: 0.8;
  }

  .hero-andy {
    position: absolute;
    top: 60%;
    right: 20%;
    transform: translateY(-50%);
    z-index: 5;
  }

  body.color-mode .hero-title h1 {
  font-family: 'Pacifico', cursive;   /* diff font only for color mode big title */
  }

  #details {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4rem 2rem;
  }

  .intro-area {
    max-width: 820px;
    text-align: center;
  }
</style>