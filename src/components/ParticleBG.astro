<div id="particle-canvas"></div>

<style>
  #particle-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script>
  import { tsParticles } from "@tsparticles/engine";
  import { loadAll } from "@tsparticles/all";
  import { loadParallaxMover } from "@tsparticles/move-parallax";

  await loadAll(tsParticles);
  await loadParallaxMover(tsParticles);

  const getDarkConfig = () => ({
    fullScreen: false,
    fpsLimit: 60,
    interactivity: {
      detectsOn: "window",
      events: { onHover: { enable: true, mode: "repulse" } },
      modes: { repulse: { distance: 100, duration: 0.4 } },
    },
    particles: {
      number: { value: 120 },
      color: { value: "#8eff8e" },
      links: { enable: true, color: "#e4ffe4", opacity: 0.3, distance: 150 },
      move: { enable: true, speed: 1.5, outModes: "bounce" },
      opacity: { value: 0.6 },
      size: { value: { min: 1, max: 3 } },
    },
    detectRetina: true,
  });

  const getColorConfig = () => ({
    fullScreen: false,
    fpsLimit: 60,
    interactivity: {
      detectsOn: "window",
      events: {
        onHover: { 
          enable: true, 
          parallax: { enable: true, force: 50, smooth: 10 },
        },
      },
    },
    particles: {
      number: { value: 200 },
      color: { value: "#ffffff" },
      links: { enable: false },
      move: { enable: false },
      size: { value: { min: 0.5, max: 2 } },
      opacity: {
        value: { min: 0.1, max: 0.9 },
        animation: {
          enable: true,
          speed: 1.5,
          sync: false,
        },
      },
        // zIndex: {
          // value: { min: 5, max: 100 },  // parallax depth feeling
          // opacityRate: 1,
          // sizeRate: 1,
          // velocityRate: 0,
        // },
    },
    detectRetina: true,
  });

  await tsParticles.load({ id: "particle-canvas", options: getDarkConfig() });


  // --- Make color mode particles retain some movement after cursor leaves page
  let lastDx = 0;
  let lastDy = 0;
  let momentum = { x: 0, y: 0 };

  window.addEventListener("mousemove", (e) => {
    const w = window.innerWidth;
    const h = window.innerHeight;
    const newDx = (e.clientX - w / 2) / (w / 2);
    const newDy = (e.clientY - h / 2) / (h / 2);
    momentum.x = (newDx - lastDx) * 0.5;
    momentum.y = (newDy - lastDy) * 0.5;
    lastDx = newDx;
    lastDy = newDy;
  });

  // when cursor leaves page, apply momentum then decay it
  document.addEventListener("mouseleave", () => {
    if (!document.body.classList.contains("color-mode")) return;
    
    function decayMomentum() {
      if (Math.abs(momentum.x) < 0.001 && Math.abs(momentum.y) < 0.001) return;
      
      // nudge tsParticles interactivity position manually
      const c = tsParticles.domItem(0);
      if (c) {
        lastDx += momentum.x;
        lastDy += momentum.y;
        // clamp so they don't drift off screen
        lastDx = Math.max(-1, Math.min(1, lastDx));
        lastDy = Math.max(-1, Math.min(1, lastDy));
        c.interactivity.mouse.position = {
          x: (lastDx + 1) / 2 * window.innerWidth,
          y: (lastDy + 1) / 2 * window.innerHeight,
        };
      }
      
      // decay momentum gradually
      momentum.x *= 0.92;
      momentum.y *= 0.92;
      requestAnimationFrame(decayMomentum);
    }
    decayMomentum();
  });
  // --- Make color mode particles retain..., end

  // Swap particles config when mode switches
  const observer = new MutationObserver(async () => {
    const isColor = document.body.classList.contains("color-mode");

    // Color flash on particles when switch dark to color mode
    if (isColor) {
      await tsParticles.load({
        id: "particle-canvas",
        options: getColorConfig(),
      });

      // wait for particles to fully initialize before color flash
      setTimeout(() => {
        const c = tsParticles.domItem(0);
        if (c) {
          c.particles._array.forEach(p => {
            p.color.h = { value: 210 };       // color hexes converted to HSL
            p.color.s = { value: 85 };      // tsParticles renders internally in HSL, not hex
            p.color.l = { value: 65 };
          });
          // gradually fade back to white
          let l = 65;
          let s = 85;
          function fadeToWhite() {
            l += (100 - l) * 0.05;   // lerp lightness toward 100
            s += (0 - s) * 0.05;     // lerp saturation toward 0
            
            c.particles._array.forEach(p => {
              p.color.l = { value: l };
              p.color.s = { value: s };
            });

            if (s > 0.5) {            // keep going until basically white
              requestAnimationFrame(fadeToWhite);
            }
          }

          setTimeout(fadeToWhite, 500);  // hold blue briefly then start fading
        }
      }, 100);  // small delay for particles to initialize first
    }
    else {
      await tsParticles.load({
        id: "particle-canvas",
        options: getDarkConfig(),
      });
    }
  });

  observer.observe(document.body, { attributeFilter: ["class"] });
</script>