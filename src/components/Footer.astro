---
import { Icon } from 'astro-icon/components';
---

<footer class="site-footer" aria-labelledby="footer-contact-heading">
  <div class="footer-inner">
    <div class="footer-brand">
      <p class="footer-kicker">&amp;Hacks 2026</p>
      <h2 id="footer-contact-heading">Keep in touch</h2>
      <p>
        Questions about the event, sponsorship, or accessibility support can go
        straight to the organizing team.
      </p>
    </div>

    <div class="footer-contact">
      <span class="footer-email">computing@wm.edu</span>
      <a
        class="footer-icon-link"
        href="https://discord.gg/ve8JwXSB"
        target="_blank"
        rel="noreferrer"
        aria-label="Discord"
      >
        <Icon name="simple-icons:discord" />
      </a>
      <a
        class="footer-icon-link"
        href="https://www.instagram.com/andhackswm/"
        target="_blank"
        rel="noreferrer"
        aria-label="Instagram"
      >
        <Icon name="simple-icons:instagram" />
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 2;
    padding: 4rem 2rem 2rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem 0 0;
    border-top: 1px solid rgba(255, 255, 255, 0.28);
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: start;
  }

  .footer-brand h2,
  .footer-brand p {
    margin: 0;
  }

  .footer-kicker {
    margin: 0 0 0.4rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    opacity: 0.62;
  }

  .footer-brand h2 {
    margin-bottom: 0.5rem;
    font-size: clamp(1.15rem, 2.4vw, 1.5rem);
  }

  .footer-brand p {
    max-width: 28rem;
    line-height: 1.5;
    opacity: 0.72;
  }

  .footer-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 1.4rem;
    justify-content: flex-end;
    text-align: right;
    padding-top: 0.15rem;
  }

  .footer-email {
    font-weight: 600;
    opacity: 0.82;
  }

  .footer-contact a {
    color: inherit;
    text-decoration: none;
  }

  .footer-contact a:hover,
  .footer-contact a:focus-visible {
    opacity: 1;
  }

  .footer-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    opacity: 0.82;
    transition: opacity 160ms ease, transform 160ms ease;
  }

  .footer-icon-link :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
    color: currentColor;
    fill: currentColor;
  }

  .footer-icon-link:hover,
  .footer-icon-link:focus-visible {
    transform: translateY(-1px);
  }

  @media (max-width: 720px) {
    .footer-inner {
      flex-direction: column;
      align-items: start;
    }

    .footer-contact {
      justify-content: flex-start;
      text-align: left;
      padding-top: 0;
    }
  }
</style>
