---
import { faqs } from '../data/faqs';
---

<section id="faq" class="faq-section" aria-labelledby="faq-heading">
  <div class="faq-inner">
    <h2 id="faq-heading">FAQ</h2>

    <div class="faq-list">
      {faqs.map((item) => (
        <details class="faq-item">
          <summary>
            <span class="faq-question">{item.question}</span>
            <span class="faq-icon" aria-hidden="true">
              <span class="faq-icon-bar faq-icon-bar-horizontal"></span>
              <span class="faq-icon-bar faq-icon-bar-vertical"></span>
            </span>
          </summary>
          <div class="faq-answer">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 4rem 2rem 6rem;
  }

  .faq-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-eyebrow {
    margin: 0 0 0.5rem;
    text-align: center;
    opacity: 0.8;
  }

  .faq-inner h2 {
    margin: 0 0 2rem;
    text-align: center;
    font-size: clamp(2rem, 5vw, 3rem);
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .faq-item {
    border: 1px solid currentColor;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.03);
    overflow: hidden;
  }

  .faq-item summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    cursor: pointer;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-question {
    font-weight: 700;
  }

  .faq-icon {
    position: relative;
    width: 1rem;
    height: 1rem;
    flex: 0 0 1rem;
    transition: transform 180ms ease;
  }

  .faq-icon-bar {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1rem;
    height: 2px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 180ms ease;
  }

  .faq-icon-bar-vertical {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-item[open] .faq-icon-bar-vertical {
    transform: translate(-50%, -50%) rotate(180deg) scaleX(0);
  }

  .faq-answer {
    padding: 0 1.25rem 1.1rem;
  }

  .faq-answer p {
    margin: 0;
    line-height: 1.6;
    opacity: 0.9;
  }
</style>
