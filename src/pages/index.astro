---
import MainLayout from '../layouts/MainLayout.astro';
import Andy from '../components/Andy.astro';
import ParticleBG from '../components/ParticleBG.astro';
import { Image } from 'astro:assets';

// Cloudy effects to add later
// import clouds from '../assets/clouds.png'; 
---

<MainLayout title="Welcome | &Hacks 2026">
  
  <ParticleBG />

  <div class="cloud-layer">
    <div style="width: 100%; height: 100%; background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);"></div>
  </div>

  <main>
    <section id="hero">
      <div class="hero-title">
        <h1>&amp;Hacks 2026</h1>
        <p>Sept. 25–27</p>
      </div>
      <div class="hero-andy">
        <Andy />
      </div>
    </section>

    <section id="details">
      <div class="schedule-area">
         <h2>Schedule</h2>
         <p>schedule stuff in progress</p>
      </div>
    </section>
  </main>
</MainLayout>

<style>
  #hero {
    position: relative;
    height: 100vh;
    width: 100%;
  }

  .hero-title {
    position: absolute;
    top: 6rem;        /* below navbar */
    left: 4rem;       /* left side */
    z-index: 5;
  }

  h1 {
    font-size: clamp(4rem, 9vw, 8rem);
    font-weight: 900;
    margin: 0;
    line-height: 1;
  }

  .hero-title p {
    font-size: 2rem;
    margin: 0.5rem 0 0 0;
    opacity: 0.8;
  }

  .hero-andy {
    position: absolute;
    top: 50%;
    right: 15%;
    transform: translateY(-50%);
    z-index: 5;
  }

  body.color-mode .hero-title h1 {
  font-family: 'Pacifico', cursive;   /* diff font only for color mode big title */
  }
</style>