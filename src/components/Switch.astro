<button id="moon-switch" aria-label="Switch color mode">
  <div class="moon">
    <div class="moon-surface"></div>
    <div class="moon-crescent"></div>
    <div class="moon-shadow"></div>
  </div>
</button>

<style>
  #moon-switch {
    opacity: 0;  /* hidden by default */
  }
  #moon-switch.ready {
    opacity: 1;
    transition: opacity 0.3s ease;
  }
  
  #moon-switch {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: none;
    background: transparent;
    cursor: pointer;
    z-index: 1000;
    padding: 0;
    filter: drop-shadow(0 0 10px rgba(255, 210, 28, 0.5));
    transition: filter 0.3s ease;
  }

  #moon-switch:hover {
    filter: drop-shadow(0 0 20px rgba(255, 210, 28, 0.66));
  }

  .moon {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    position: relative;
    overflow: hidden;
  }

  .moon-surface {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #ffd21c;
    transition: background 0.6s ease;
  }

  .moon-crescent {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: transparent;
    box-shadow: inset 8px 0 0 rgba(0, 0, 0, 0.25);
    z-index: 2;
    pointer-events: none;
  }

  .moon-shadow {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #272727;
    transform: translateX(-100%);
    transition: none;
    z-index: 1;
  }

  #moon-switch.dark .moon-surface {
    background: #d3d3d3;
  }

  #moon-switch.dark .moon-shadow {
    transform: translateX(20%);
    background: #272727;
  }

  #moon-switch.dark {
    filter: drop-shadow(0 0 10px rgba(0, 182, 0, 0.95));
  }

  #moon-switch.dark:hover {
    filter: drop-shadow(0 0 20px rgba(0, 255, 0, 0.87));
  }

  /* ring pulse */
  #moon-switch::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid rgba(255, 210, 28, 0.26);
    animation: pulse 3.0s ease-out infinite;
    pointer-events: none;
  }

  #moon-switch.dark::before {
    border-color: rgba(0, 175, 0, 0.75);  /* ring pulse in dark mode */
  }

  @keyframes pulse {
    0%   { transform: scale(1);   opacity: 0.3; }
    70%  { transform: scale(1.4); opacity: 0;   }
    100% { transform: scale(1.4); opacity: 0;   }
  }
</style>

<script>
  const moonBtn = document.getElementById('moon-switch');
  const heroTitle = document.querySelector('.hero-title');
  const navbar = document.getElementById('navbar');

  // set initial state
  if (document.body.classList.contains('dark-mode')) {
    moonBtn.classList.add('dark');
  }
  // show switch only after correct state is set
  moonBtn.classList.add('ready');

  moonBtn?.addEventListener('click', () => {
    heroTitle?.classList.add('glitching');
    navbar?.classList.add('glitching');

    const shadow = document.querySelector('.moon-shadow');
    const isCurrentlyDark = document.body.classList.contains('dark-mode');

    if (isCurrentlyDark) {
      // dark to color: shadow exits right
      shadow.style.transition = 'transform 1.2s cubic-bezier(0.4, 0, 0.2, 1)';
      shadow.style.transform = 'translateX(100%)';
      setTimeout(() => {
        shadow.style.transition = 'none';
        shadow.style.transform = 'translateX(-100%)';
      }, 1200);
    } else {
      // color to dark: shadow enters from left, sweeps right to cover
      shadow.style.transition = 'none';
      shadow.style.transform = 'translateX(-100%)';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          shadow.style.transition = 'transform 1.2s cubic-bezier(0.4, 0, 0.2, 1)';
          shadow.style.transform = 'translateX(20%)';
        });
      });
    }

    setTimeout(() => {
      const isColor = document.body.classList.toggle('color-mode');
      document.body.classList.toggle('dark-mode', !isColor);
      moonBtn.classList.toggle('dark', !isColor);
    }, 250);

    setTimeout(() => {
      heroTitle?.classList.remove('glitching');
      navbar?.classList.remove('glitching');
    }, 500);
  });

  // auto switch to color mode on first load
  const hasVisited = sessionStorage.getItem('hasVisited');
  if (!hasVisited) {
    sessionStorage.setItem('hasVisited', 'true');
    setTimeout(() => {
      // trigger the same click behavior programmatically
      moonBtn.click();
    }, 3000);  // 5 seconds after load
  }