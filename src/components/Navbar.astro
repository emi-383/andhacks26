<nav id="navbar">
  <div class="nav-inner">
    <a href="#about">About</a>
    <a href="#schedule">Schedule</a>
    <a href="#top">Register</a>
    <a href="#top">Sponsor</a>
    <a href="#contact">Contact</a>
  </div>
</nav>

<style>
  #navbar {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    background: transparent;
    transition: background 0.3s ease;
  }

  /* Dark mode scrolled down solid color */
  #navbar.scrolled {
    background: #1a1a1a;
  }

  /* Color mode scrolled down solid color */
  body.color-mode #navbar.scrolled {
    background: #2a1f6e;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 2rem;
    padding: 1rem;
  }

  a {
    color: white !important;   /* make sure text color doesnt change when clicked */
    text-decoration: none;
    font-weight: 500;
    transition: text-shadow 0.3s ease;   /* glow fade timing */
  }

  a:visited,
  a:active,
  a:hover{       /* glow on hover */
    color: white !important;
    text-shadow: 
      0 0 8px rgba(255, 255, 255, 0.9),
      0 0 20px rgba(255, 255, 255, 0.6),
      0 0 40px rgba(255, 255, 255, 0.3);
    transition: text-shadow 0.3s ease;
  },
  a:focus {
    color: white !important;
  }
</style>

<script>
  const navbar = document.getElementById('navbar');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  });
</script>