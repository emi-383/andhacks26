<div class="terminal">
  <div class="terminal-bar">
    <span class="dot red"></span>
    <span class="dot yellow"></span>
    <span class="dot green"></span>
    <span class="terminal-name">bash</span>
  </div>
  <div class="terminal-body">
    <div class="line1">
      <span class="prompt">$ </span><span class="typed-input"></span><span class="cursor">▋</span>
    </div>
    <div class="line2">
      <span class="output"></span>
    </div>
  </div>
</div>

<style>
  .terminal {
    background: #0d0d0d;
    border-radius: 10px;
    overflow: hidden;
    display: inline-block;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    border: 1px solid #333;
    min-width: 400px;
  }

  .terminal-bar {
    background: #1e1e1e;
    padding: 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red    { background: #ff5f57; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green  { background: #28c840; }

  .terminal-name {
    color: #888;
    font-size: 0.8rem;
    margin-left: auto;
    margin-right: auto;
    font-family: monospace;
  }

  .terminal-body {
    padding: 1rem 1.2rem;
    font-family: 'Courier New', monospace;
    font-size: 1.1rem;
    color: #00ff00;
    min-height: 2.5rem;
    text-align: left;
  }

  .line2 {
    margin-top: 0.4rem;
  }

  .output {
    color: #00ff00;
    opacity: 0.85;
    font-family: 'Courier New', monospace;
  }

  .prompt {
    color: #00ff00;
    opacity: 0.7;
  }

  .cursor {
    animation: blink 1s step-end infinite;
    color: #00ff00;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script>
  const input = "imagination & AI --merge";
  const output = "imaginAItion";
  const inputEl = document.querySelector('.typed-input');
  const outputEl = document.querySelector('.output');
  const cursor = document.querySelector('.cursor');
  let i = 0;

  function typeInput() {
    if (i < input.length) {
      inputEl.textContent += input[i];
      i++;
      setTimeout(typeInput, 60);
    } else {
      // input done, pause then show output
      cursor.style.display = 'none';
      setTimeout(showOutput, 500);
    }
  }

  function showOutput() {
    outputEl.textContent = '> ' + output;
  }

  // start anim when terminal in full view
  const terminal = document.querySelector('.terminal');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        setTimeout(typeInput, 400);
        observer.disconnect();
      }
    });
  }, { threshold: 1.0 });

  observer.observe(terminal);
</script>