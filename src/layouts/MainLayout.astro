---
// src/layouts/MainLayout.astro
import '../styles/global.css';
const { title = "Hackathon 2026" } = Astro.props;
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body class="dark-mode">
		<slot /> <style is:global>
			:root { --transition-speed: 1.2s; }
			body { margin: 0; transition: background var(--transition-speed), filter var(--transition-speed); }
			
			/* Dark mode */
			body.dark-mode { background: #000; filter: grayscale(100%); color: #00ff00; }
			
			/* Color mode */
			body.imagination-mode { background: #1a1a2e; filter: grayscale(0%); color: #fff; }
		</style>
	</body>
</html>