---
// src/components/Andy.astro
import { Image } from 'astro:assets';
import andyImg from '../assets/andy_conceptart_colored.png';
---

<div id="andy-trigger" class="andy-wrap">
  <Image src={andyImg} alt="Andy" width={300} height={300} />
  <p class="status-text">text for off mode. click to switch</p>
</div>

<style>
  .andy-wrap {
    cursor: pointer;
    text-align: center;
    z-index: 10;
  }
  .andy-wrap:hover { transform: scale(1.05); transition: 0.3s; }
</style>

<script>
  const andy = document.getElementById('andy-trigger');
  const status = document.querySelector('.status-text');

  andy?.addEventListener('click', () => {
    const isColor = document.body.classList.toggle('color-mode');
    document.body.classList.toggle('dark-mode', !isColor); 
    
    if (status) {
      status.textContent = isColor ? "text for on mode. click to switch" : "text for off mode. click to switch";
    }
  });
</script>