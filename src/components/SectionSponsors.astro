---
import wmLogo from '../assets/wm_logo_placeholder.png';
import wmLogo2 from '../assets/wm_logo_2.png';

const row = [
  {
    id: 'wm-1',
    src: wmLogo.src,
    alt: 'William & Mary logo',
    href: 'mailto:computing@wm.edu?subject=%26Hacks%20Sponsorship',
  },
  {
    id: 'wm-2',
    src: wmLogo2.src,
    alt: 'William & Mary logo',
    href: 'mailto:computing@wm.edu?subject=%26Hacks%20Sponsorship',
  },
  {
    id: 'wm-3',
    src: wmLogo.src,
    alt: 'William & Mary logo',
    href: 'mailto:computing@wm.edu?subject=%26Hacks%20Sponsorship',
  },
  {
    id: 'wm-4',
    src: wmLogo2.src,
    alt: 'William & Mary logo',
    href: 'mailto:computing@wm.edu?subject=%26Hacks%20Sponsorship',
  },
];

const rows = [
  { items: row, dir: 'left' },
  { items: row.map((item, index) => ({ ...item, id: `wm-b-${index}` })), dir: 'right' },
  { items: row.map((item, index) => ({ ...item, id: `wm-c-${index}` })), dir: 'left' },
];
---

<section id="sponsors" class="sponsors-section" aria-label="Sponsors">
  <div class="sponsors-inner">
    {rows.map((rowData, rowIndex) => (
      <div class="sponsor-row-shell">
        <div
          class:list={[
            'sponsor-track',
            rowData.dir === 'right' ? 'sponsor-track-right' : 'sponsor-track-left',
          ]}
        >
          {[...rowData.items, ...rowData.items].map((item, itemIndex) => (
            <a
              class="sponsor-card"
              href={item.href}
              aria-hidden={itemIndex >= rowData.items.length ? 'true' : 'false'}
            >
              <img
                src={item.src}
                alt={item.alt}
                loading={rowIndex === 0 && itemIndex < rowData.items.length ? 'eager' : 'lazy'}
              />
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .sponsors-section {
    position: relative;
    width: 100%;
    background: #3a337e;
    overflow: hidden;
    padding: 1rem 0;
    margin-bottom: 6rem;
    scroll-margin-top: 80px;
  }

  .sponsors-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    z-index: 1;
  }

  .sponsor-row-shell {
    width: 100%;
    overflow: hidden;
  }

  .sponsor-row-shell:hover .sponsor-track {
    animation-play-state: paused;
  }

  .sponsor-track {
    display: flex;
    align-items: center;
    width: max-content;
    gap: 1.25rem;
  }

  .sponsor-track-left {
    animation: sponsor-scroll-left 28s linear infinite;
  }

  .sponsor-track-right {
    animation: sponsor-scroll-right 28s linear infinite;
  }

  .sponsor-card {
    position: relative;
    flex: 0 0 auto;
    width: clamp(136px, 18vw, 228px);
    height: clamp(84px, 11vw, 142px);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1rem;
    background: #7a87b6;
    text-decoration: none;
    padding: 0.8rem;
  }

  .sponsor-card img {
    width: 82%;
    height: 82%;
    object-fit: contain;
    display: block;
    filter: saturate(1.02) brightness(1.02);
  }

  @keyframes sponsor-scroll-left {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(calc(-50% - 0.625rem));
    }
  }

  @keyframes sponsor-scroll-right {
    from {
      transform: translateX(calc(-50% - 0.625rem));
    }

    to {
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sponsor-track {
      animation: none;
    }
  }

  @media (min-width: 768px) {
    .sponsors-section {
      margin-bottom: 7rem;
    }

    .sponsor-track {
      gap: 1.75rem;
    }
  }
</style>
